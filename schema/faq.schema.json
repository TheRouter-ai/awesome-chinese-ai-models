{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FaqEntry",
  "type": "object",
  "required": ["id", "question", "answer"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "question": {"type": "string"},
    "answer": {"type": "string"}
  }
}
